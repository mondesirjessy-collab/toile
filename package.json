    "test:watch": "vitest",
    "bench": "vitest bench --run"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.44",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
